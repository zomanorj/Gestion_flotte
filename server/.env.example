# .env.example
# Modèle de fichier de configuration pour le serveur Transport STTA.
# Copier ce fichier en ".env" et remplir les valeurs réelles.
# NE JAMAIS committer le fichier .env dans Git.

# Port d'écoute du serveur Express
PORT=5000

# URL complète de connexion à la base de données PostgreSQL
# Format : postgresql://utilisateur:motdepasse@hote:port/nom_base
DATABASE_URL=postgresql://postgres:motdepasse@localhost:5432/transport_stta

# Clé secrète utilisée pour signer les tokens JWT (authentification)
# Utiliser une chaîne longue et aléatoire en production
JWT_SECRET=changez_cette_valeur_en_production

# Durée de validité d'un token JWT (ex: "1d", "8h", "30m")
JWT_EXPIRES_IN=1d

# URL du client React (pour la configuration CORS)
CLIENT_URL=http://localhost:5173
