# .gitignore
# Fichiers et dossiers à exclure du dépôt Git pour le projet Transport STTA.

# ---- Dépendances ----
node_modules/
client/node_modules/
server/node_modules/

# ---- Fichiers d'environnement (contiennent des secrets) ----
.env
server/.env
client/.env
*.env.local
# Ne pas committer .env.production (contient des URLs de production potentiellement privées)
# Utiliser les variables d'environnement du dashboard Vercel/Render à la place
# client/.env.production  ← décommenté si on ne veut pas le committer

# ---- Worktrees Claude Code (dossiers temporaires) ----
.claude/worktrees/

# ---- Build / compilation ----
client/dist/
client/build/
server/dist/

# ---- Logs ----
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# ---- Éditeurs et OS ----
.DS_Store
Thumbs.db
.vscode/settings.json
.idea/
*.swp
*.swo

# ---- TypeScript ----
*.tsbuildinfo
